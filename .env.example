# Azure Postgres Database
# Use PgBouncer port 6432 (already active on the Flexible Server)
# sslmode=verify-full is required — SSL config is driven by the URL, not code
# Format: postgresql://<user>:<pass>@<host>:6432/<db>?sslmode=verify-full
DATABASE_URL=
ODS_TOKEN=
AZURE_OPENAI_ENDPOINT=https://{resource}.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_API_KEY=
